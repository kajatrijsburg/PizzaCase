<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PizzaCaseApp.Pages.SettingsPage"
             Title="SettingsPage">
    <VerticalStackLayout>
        <StackLayout
            Orientation="Horizontal"
            Margin="10">
            <Label
                Text="ip:"
                VerticalOptions="Center"
                Margin="5"/>
            <Entry
                Placeholder="0.0.0.0"
                Margin="5"/>
        </StackLayout>
        <StackLayout
            Orientation="Horizontal"
            Margin="10">
            <Label
                Text="Protocol: "
                VerticalOptions="Center"
                Margin="5"/>
            <Picker/>
        </StackLayout>
    </VerticalStackLayout>
</ContentPage>